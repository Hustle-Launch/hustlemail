# SMTP Server Configuration
PORT=25
HOSTNAME=mail.yourdomain.com

# Convex HTTP Actions
# Get URL from your Convex dashboard
# Get API key from `bunx convex run auth:generateKey`
CONVEX_URL=https://your-project.convex.cloud
CONVEX_API_KEY=convex_api_key_...

# Spam Detection (OpenRouter - free tier available)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Webhook for processed emails
WEBHOOK_URL=https://yourdomain.com/api/inbound
WEBHOOK_SECRET=your-secure-webhook-secret

# Logging
LOG_LEVEL=info
