# CodeMail SMTP Server Configuration

# Server
SMTP_PORT=25
SMTP_HOST=0.0.0.0
SMTP_SECURE=false

# TLS (required if SMTP_SECURE=true)
# TLS_KEY_PATH=/path/to/key.pem
# TLS_CERT_PATH=/path/to/cert.pem

# Convex (required)
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:your-deploy-key

# OpenRouter for AI spam evaluation (required)
OPENROUTER_API_KEY=sk-or-v1-...
SPAM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Limits
MAX_MESSAGE_SIZE=26214400  # 25MB
MAX_ATTACHMENT_SIZE=1048576  # 1MB inline threshold
CONNECTION_TIMEOUT=300000  # 5 minutes

# Logging
LOG_LEVEL=info  # debug | info | warn | error
